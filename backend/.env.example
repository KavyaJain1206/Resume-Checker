# PostgreSQL is required — there is no fallback store. Use the async driver
# scheme (postgresql+asyncpg://) or a plain postgresql:// URL (auto-upgraded).
DATABASE_URL=postgresql+asyncpg://resume_app:CHANGE_ME@localhost:5432/resume_playbook
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_ECHO=false

# Placement-admin credentials (Student Arsenal login) — REQUIRED, no
# fallback default exists in code. The app refuses to start without these.
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
SECRET_KEY=replace-with-a-long-random-secret

CORS_ORIGINS=http://localhost:5173
PORT=8000

# "development" enables uvicorn --reload when running server.py directly
ENVIRONMENT=development
LOG_LEVEL=INFO
